# Dominio DDS condiviso da backend e nodi (demo o robot reale).
# Allinealo al ROS_DOMAIN_ID del robot, oppure cambialo a caldo dalla UI.
ROS_DOMAIN_ID          = "1"
# Implementazione RMW di default per Humble.
RMW_IMPLEMENTATION     = rmw_fastrtps_cpp
# Avvia automaticamente i nodi demo all'avvio del container.
# Imposta "0" per osservare SOLO il ROS reale (vedi docs/ros/real-ros.md).
COMBO_DEBUG_START_DEMO = "0"

# --- Autenticazione della dashboard (opt-in) --------------------------------
# Disabilitata di default: la dashboard e' accessibile senza login. Imposta
# COMBO_DEBUG_AUTH_ENABLED=true per richiedere il login. Cambia SEMPRE il segreto
# e la password in un deployment reale.
COMBO_DEBUG_AUTH_ENABLED  = "false"
COMBO_DEBUG_AUTH_USERNAME = "admin"
COMBO_DEBUG_AUTH_PASSWORD = "combo-debug"
COMBO_DEBUG_AUTH_SECRET   = "change-me-combo-debug-secret"
